# ── App ────────────────────────────────────────────────────────────────
APP_NAME="AI Investment Support Platform"
DEBUG=false

# ── Database (postgresql+asyncpg 필수) ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/investment_db

# ── Security ───────────────────────────────────────────────────────────
# openssl rand -hex 32 으로 생성
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_STRONG_RANDOM_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis / Celery ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── 한국투자증권 KIS Developers API ───────────────────────────────────
KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret
KIS_ACCOUNT_NO=your_account_number

# ── Open DART API ─────────────────────────────────────────────────────
DART_API_KEY=your_dart_api_key

# ── sec-api.io (내부자 거래) ──────────────────────────────────────────
SEC_API_KEY=your_sec_api_key

# ── Google Gemini ─────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_CACHE_TTL_SECONDS=3600
